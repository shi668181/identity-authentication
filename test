import cv2
import numpy as np
import json
import os
from pathlib import Path

# ===================== 설정 =====================
USER_FILE = "users.json"
FACE_DIR = "face_save"
Path(FACE_DIR).mkdir(exist_ok=True)

# 사용자 정보 불러오기
def load_users():
    if os.path.exists(USER_FILE):
        with open(USER_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

# 사용자 정보 저장
def save_users(users):
    with open(USER_FILE, "w", encoding="utf-8") as f:
        json.dump(users, f, indent=2)

# 얼굴 이미지 저장
def save_face_img(username, face_img):
    path = os.path.join(FACE_DIR, f"{username}.jpg")
    cv2.imwrite(path, face_img)

# 얼굴 이미지 불러오기
def load_face_img(username):
    path = os.path.join(FACE_DIR, f"{username}.jpg")
    if os.path.exists(path):
        return cv2.imread(path, cv2.IMREAD_GRAYSCALE)
    return None

# OpenCV 얼굴 검출기 로드
face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + "haarcascade_frontalface_default.xml")

# ===================== 회원가입 =====================
def register():
    users = load_users()
    print("\n===== 회원가입 =====")
    username = input("사용자 이름 입력：")

    if username in users:
        print("이미 존재하는 사용자 이름입니다!")
        return

    password = input("비밀번호 입력：")
    print("\nS 를 눌러 얼굴 저장 | ESC 취소")

    cap = cv2.VideoCapture(0)
    saved_face = None

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        faces = face_cascade.detectMultiScale(gray, 1.3, 5)

        for (x, y, w, h) in faces:
            cv2.rectangle(frame, (x, y), (x + w, y + h), (0, 255, 0), 2)

        cv2.imshow("회원가입", frame)
        key = cv2.waitKey(1) & 0xFF

        if key == 27:
            print("회원가입 취소됨")
            cap.release()
            cv2.destroyAllWindows()
            return

        if key == ord("s"):
            if len(faces) == 1:
                x, y, w, h = faces[0]
                saved_face = gray[y:y + h, x:x + w]
                print("얼굴 저장 완료")
                break
            else:
                print("화면에 얼굴이 하나만 있도록 해주세요")

    cap.release()
    cv2.destroyAllWindows()

    users[username] = password
    save_users(users)
    save_face_img(username, saved_face)
    print(f"사용자 {username} 회원가입 완료!")

# ===================== 로그인 =====================
def login():
    users = load_users()
    print("\n===== 로그인 =====")
    username = input("사용자 이름：")
    password = input("비밀번호：")

    # 1. 계정 비밀번호 확인
    if username not in users or users[username] != password:
        print("계정 또는 비밀번호 오류")
        return False

    # 2. 등록된 얼굴 불러오기
    saved_face = load_face_img(username)
    if saved_face is None:
        print("얼굴 데이터를 찾을 수 없습니다")
        return False

    # 3. 얼굴 대조
    print("\n얼굴 인증 중... ESC 취소")
    cap = cv2.VideoCapture(0)
    match = False

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        faces = face_cascade.detectMultiScale(gray, 1.3, 5)

        # 얼굴 검출 시 대조 실행
        if len(faces) == 1:
            x, y, w, h = faces[0]
            current_face = gray[y:y + h, x:x + w]
            resized_face = cv2.resize(current_face, (saved_face.shape[1], saved_face.shape[0]))

            # 유사도 계산
            diff = cv2.absdiff(saved_face, resized_face)
            score = np.mean(diff)
            if score < 40:
                match = True

        # 결과 표시
        color = (0, 255, 0) if match else (0, 0, 255)
        text = "통과" if match else "실패"
        cv2.putText(frame, text, (50, 50), cv2.FONT_HERSHEY_SIMPLEX, 1, color, 2)

        for (x, y, w, h) in faces:
            cv2.rectangle(frame, (x, y), (x + w, y + h), color, 2)

        cv2.imshow("로그인 인증", frame)

        if cv2.waitKey(1) & 0xFF == 27:
            print("로그인 취소됨")
            cap.release()
            cv2.destroyAllWindows()
            return False

        if match:
            print("✅ 얼굴 인증 성공! 로그인 완료")
            cap.release()
            cv2.destroyAllWindows()
            return True

# ===================== 메인 프로그램 =====================
def main():
    print("===== 얼굴인식 로그인 시스템 =====")
    while True:
        print("\n1 회원가입")
        print("2 로그인")
        print("3 종료")
        choice = input("선택：")

        if choice == "1":
            register()
        elif choice == "2":
            if login():
                print("\n🎉 시스템에 오신 것을 환영합니다!")
        elif choice == "3":
            print("프로그램 종료")
            break
        else:
            print("잘못된 입력입니다")

if __name__ == "__main__":
    main()
