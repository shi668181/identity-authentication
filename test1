import cv2
import numpy as np

# ===================== Global Variables =====================
template_img = None       
template_thin = None      
is_collecting = False     
WINDOW_NAME = "Fingerprint Capture & Real-Time Matching"

# ===================== Fingerprint Preprocessing =====================
def preprocess_finger(frame):
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (3, 3), 0)
    
    binary = cv2.adaptiveThreshold(
        blur, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
        cv2.THRESH_BINARY_INV, 15, 2
    )
    
    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (2, 2))
    binary = cv2.morphologyEx(binary, cv2.MORPH_OPEN, kernel, iterations=1)
    thin = cv2.ximgproc.thinning(binary)
    return gray, binary, thin

def match_finger(template_thin, test_thin):
    if template_thin is None or test_thin is None:
        return 0.0
    
    diff = cv2.absdiff(template_thin, test_thin)
    total_pixel = diff.size
    same_pixel = total_pixel - np.count_nonzero(diff)
    score = (same_pixel / total_pixel) * 100
    return round(score, 2)

# ===================== Help Text =====================
def show_help(frame):
    cv2.putText(frame, "'s' = Save Template", (10, 30), 
                cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)
    cv2.putText(frame, "'q' = Quit", (10, 60), 
                cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)
    cv2.putText(frame, "'r' = Reset Template", (10, 90), 
                cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)
    return frame

# ===================== Main Program =====================
def run_fingerprint_system():
    global template_img, template_thin, is_collecting
    
    cap = cv2.VideoCapture(0)
    cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
    
    print("===== Fingerprint System Started =====")
    print("Controls:")
    print(" s : Save current frame as fingerprint template")
    print(" r : Clear template")
    print(" q : Exit")
    
    while True:
        ret, frame = cap.read()
        if not ret:
            print("Failed to open camera!")
            break
        
        frame = cv2.flip(frame, 1)
        display = frame.copy()
        
        gray, binary, thin = preprocess_finger(frame)
        score = match_finger(template_thin, thin)
        
        if template_thin is not None:
            cv2.putText(display, f"Score: {score}%", (400, 40),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.9, (255, 0, 0), 2)
            if score > 70:
                cv2.putText(display, "MATCHED", (400, 80),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 255, 0), 3)
            else:
                cv2.putText(display, "NO MATCH", (400, 80),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 0, 255), 3)
        else:
            cv2.putText(display, "No Template", (400, 40),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 0, 255), 2)
        
        display = show_help(display)
        
        binary_color = cv2.cvtColor(binary, cv2.COLOR_GRAY2BGR)
        thin_color = cv2.cvtColor(thin, cv2.COLOR_GRAY2BGR)
        
        top = np.hstack((display, binary_color, thin_color))
        top = cv2.resize(top, (1280, 480))
        
        cv2.imshow(WINDOW_NAME, top)
        
        key = cv2.waitKey(1) & 0xFF
        
        if key == ord('s'):
            template_img = gray
            template_thin = thin
            print("\n✅ Fingerprint template saved!")
        
        if key == ord('r'):
            template_img = None
            template_thin = None
            print("\n🔄 Template cleared!")
        
        if key == ord('q'):
            print("\n👋 System exited.")
            break
    
    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    run_fingerprint_system() 
