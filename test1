import cv2
import numpy as np
import matplotlib.pyplot as plt

# ===================== 指纹识别核心类 =====================
class FingerprintRecognition:
    def __init__(self):
        # 初始化SIFT特征提取器（指纹特征提取专用算法）
        self.sift = cv2.SIFT_create()
        # FLANN匹配器（快速特征匹配，生物识别常用）
        index_params = dict(algorithm=1, trees=5)
        search_params = dict(checks=50)
        self.flann = cv2.FlannBasedMatcher(index_params, search_params)

    def preprocess(self, img_path):
        """
        指纹预处理：灰度化+二值化+细化（指纹识别标准步骤）
        """
        # 读取图像
        img = cv2.imread(img_path)
        if img is None:
            raise FileNotFoundError("未找到指纹图像！")
        
        # 1. 灰度化
        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        # 2. 高斯模糊去噪
        blur = cv2.GaussianBlur(gray, (3, 3), 0)
        # 3. 二值化（黑白分离指纹纹路）
        _, binary = cv2.threshold(blur, 127, 255, cv2.THRESH_BINARY_INV)
        # 4. 形态学细化（提取指纹核心纹路）
        kernel = np.ones((2, 2), np.uint8)
        thin = cv2.morphologyEx(binary, cv2.MORPH_GRADIENT, kernel)
        
        return img, gray, binary, thin

    def extract_features(self, processed_img):
        """
        提取指纹SIFT特征（关键点+特征向量）
        """
        kp, des = self.sift.detectAndCompute(processed_img, None)
        return kp, des

    def match_fingerprints(self, des1, des2, threshold=50):
        """
        指纹匹配：计算两个指纹特征相似度
        :return: 匹配点数、相似度（%）
        """
        if des1 is None or des2 is None:
            return 0, 0.0
        
        # 快速匹配特征
        matches = self.flann.knnMatch(des1, des2, k=2)
        # 优质匹配筛选（Lowe比率测试）
        good_matches = []
        for m, n in matches:
            if m.distance < 0.7 * n.distance:
                good_matches.append(m)
        
        # 计算相似度
        max_feat = min(len(des1), len(des2))
        similarity = len(good_matches) / max_feat * 100 if max_feat > 0 else 0.0
        return len(good_matches), round(similarity, 2)

